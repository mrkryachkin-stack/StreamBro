# StreamBro - .gitignore
# Protects server architecture, internal docs, and build artifacts from public repo.

# - Node / Electron -
node_modules/
dist/
out/

# - OS junk -
Thumbs.db
.DS_Store
desktop.ini
*.log

# - Private / internal docs - NOT for public repo -
# These contain server architecture, security model, and deployment plans
# that give competitive advantage. Share only with team members directly.
docs/SERVER_PLAN.md
docs/SECURITY.md
docs/BUILD_NOTES.md

# - Backups - development history, not for repo -
backups/

# - Vendor binaries - too large for git, distributed via releases -
vendor/ffmpeg.exe

# - Dev tools -
.cursor/
*.swp
*.swo
*~

# - IDE -
.idea/
.vscode/
*.code-workspace

# - Server data (generated at runtime) -
server/data/
server/logs/
server/node_modules/

# - Temp / cache -
*.tmp
*.bak
.env
.env.local
.env.production
.env.*.local
StreamBro-*-portable.zip

# - Deploy scripts with secrets (NEVER commit these) -
tmp_*.py
deploy_icons.py
_deploy.py
_check*.py
_verify.py
_find_*.py
_test_*.py
_deploy_*.py
_convert_*.js
_check_vk.py
streambro-setup.sh
_ssh-check-site.js

# - Internal docs with credentials -
ИТОГ_РАБОТЫ.md
StreamBro key.txt

# - Debug scripts -
tmp_dbg*.py