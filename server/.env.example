# StreamBro Server — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit real secrets to git!

# Server
PORT=3000
NODE_ENV=production

# JWT secret (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-64-char-string

# Admin secret (generate: openssl rand -hex 32)
ADMIN_SECRET=change-me-to-a-strong-secret

# Database
DATABASE_URL=postgresql://streambro:change-me@localhost:5432/streambro

# TURN relay
COTURN_SECRET=change-me

# Frontend URL (for CSRF and redirects)
FRONTEND_URL=https://streambro.ru

# Cookie domain (for production)
COOKIE_DOMAIN=.streambro.ru

# Cloudflare R2 (for backups, optional)
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=

# Bug reports endpoint (used by desktop app)
BUGS_DIR=./data/bugs

# Updates
UPDATES_DIR=./data/updates
APP_VERSION=1.2.4

# Signaling (used by signaling.js)
SIGNALING_PORT=7890

# ─── AI Bot Providers ───────────────────────────────────────
# At least one provider must be configured for the AI support bot to work.
# If none are set, the bot is disabled and messages go to human admin.
#
# MULTIPLE KEYS: separate with commas for rate limit distribution.
# Example: FIREWORKS_API_KEY=fw_key1,fw_key2,fw_key3
# The bot rotates keys via round-robin on each request.

# Ollama (local LLM — free, private)
# OLLAMA_ENDPOINT=http://localhost:11434/v1
# OLLAMA_MODEL=llama3
# OLLAMA_KEY=ollama

# Fireworks AI (cloud — fast, OpenAI-compatible)
# FIREWORKS_API_KEY=fw_your_key_here
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# FIREWORKS_MODEL=accounts/fireworks/models/glm-5p1

# Groq (cloud — very fast, free tier available)
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (cloud — generous free tier)
# GEMINI_API_KEY=AIza_your_key_here
# GEMINI_MODEL=gemini-2.0-flash
