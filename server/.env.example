# StreamBro Server — Environment Variables
# Copy this to .env and fill in real values
# NEVER commit real secrets to git!

# Server
PORT=3000
NODE_ENV=production

# JWT secret (generate: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-64-char-string

# Admin secret (generate: openssl rand -hex 32)
ADMIN_SECRET=change-me-to-a-strong-secret

# Database
DATABASE_URL=postgresql://streambro:change-me@localhost:5432/streambro

# TURN relay
COTURN_SECRET=change-me

# Frontend URL (for CSRF and redirects)
FRONTEND_URL=https://streambro.ru

# Cookie domain (for production)
COOKIE_DOMAIN=.streambro.ru

# Cloudflare R2 (for backups, optional)
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=

# Bug reports endpoint (used by desktop app)
BUGS_DIR=./data/bugs

# Updates
UPDATES_DIR=./data/updates
APP_VERSION=1.2.4

# Signaling (used by signaling.js)
SIGNALING_PORT=7890
