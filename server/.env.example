# StreamBro Server — Environment Variables
# Copy this to .env and fill in real values

# Server
PORT=3000
NODE_ENV=production

# Admin secret for /bugs GET, /bugs/stats, /bugs/:id DELETE
ADMIN_SECRET=change-me-to-a-strong-secret

# Bug reports endpoint (used by desktop app)
BUGS_DIR=./data/bugs

# Updates
UPDATES_DIR=./data/updates
APP_VERSION=1.1.0

# Signaling (used by signaling.js)
SIGNALING_PORT=7890
